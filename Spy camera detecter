<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">
    <title>CyberShield Pro - Advanced Spy Camera Detector</title>
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.0.0"></script>
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow-models/coco-ssd@2.2.3"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0b0f19 0%, #1a1f35 100%);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 900px;
            background: #111827;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 8px 32px 0 rgba(0, 242, 254, 0.15), inset 0 1px 0 0 rgba(255, 255, 255, 0.1);
            border: 1px solid #1f2937;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        h1 {
            font-size: 32px;
            color: #00f2fe;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(0, 242, 254, 0.5);
        }

        .subtitle {
            color: #9ca3af;
            font-size: 14px;
            margin-bottom: 15px;
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }
        }

        .camera-section {
            display: flex;
            flex-direction: column;
        }

        .camera-box {
            position: relative;
            width: 100%;
            aspect-ratio: 4/3;
            background: #030712;
            border-radius: 15px;
            overflow: hidden;
            border: 2px solid #374151;
            margin-bottom: 15px;
        }

        video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1);
        }

        canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
        }

        .status-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 12px;
            font-weight: bold;
            display: none;
            backdrop-filter: blur(10px);
            animation: blink 1.5s infinite;
        }

        .status-badge.recording {
            background: rgba(239, 68, 68, 0.9);
            color: #fff;
        }

        .status-badge.active {
            background: rgba(34, 197, 94, 0.9);
            color: #fff;
        }

        @keyframes blink {
            50% { opacity: 0.5; }
        }

        .alert-box {
            position: absolute;
            bottom: 15px;
            left: 15px;
            right: 15px;
            background: rgba(239, 68, 68, 0.95);
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            display: none;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .stats-panel {
            background: #1f2937;
            padding: 20px;
            border-radius: 15px;
            border: 1px solid #374151;
        }

        .stat-item {
            margin-bottom: 15px;
            padding: 10px;
            background: #111827;
            border-radius: 8px;
            border-left: 3px solid #00f2fe;
        }

        .stat-label {
            font-size: 12px;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-value {
            font-size: 18px;
            color: #00f2fe;
            font-weight: bold;
            margin-top: 5px;
        }

        .control-panel {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }

        button {
            background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
            border: none;
            color: #000;
            padding: 12px 20px;
            font-size: 14px;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        button:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 5px 20px rgba(0, 242, 254, 0.4);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        button.secondary {
            background: #1f2937;
            color: #fff;
            border: 1px solid #374151;
        }

        button.secondary:hover:not(:disabled) {
            background: #374151;
            box-shadow: 0 5px 15px rgba(0, 242, 254, 0.3);
        }

        button.danger {
            background: #ef4444;
            color: #fff;
        }

        button.danger:hover:not(:disabled) {
            background: #dc2626;
        }

        .filter-controls {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 15px;
        }

        .filter-slider {
            display: flex;
            flex-direction: column;
        }

        .filter-slider label {
            font-size: 12px;
            color: #9ca3af;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        input[type="range"] {
            width: 100%;
            height: 6px;
            background: #374151;
            border-radius: 3px;
            outline: none;
            -webkit-appearance: none;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            background: #00f2fe;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(0, 242, 254, 0.5);
        }

        input[type="range"]::-moz-range-thumb {
            width: 18px;
            height: 18px;
            background: #00f2fe;
            border-radius: 50%;
            cursor: pointer;
            border: none;
            box-shadow: 0 0 10px rgba(0, 242, 254, 0.5);
        }

        .error-message {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid #ef4444;
            color: #fca5a5;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 15px;
            display: none;
            animation: slideIn 0.3s ease;
        }

        .success-message {
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid #22c55e;
            color: #86efac;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 15px;
            display: none;
            animation: slideIn 0.3s ease;
        }

        .info-box {
            background: rgba(59, 130, 246, 0.1);
            border: 1px solid #3b82f6;
            color: #93c5fd;
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 15px;
        }

        .detection-log {
            background: #1f2937;
            padding: 15px;
            border-radius: 8px;
            max-height: 200px;
            overflow-y: auto;
            font-size: 12px;
            border: 1px solid #374151;
        }

        .log-entry {
            color: #9ca3af;
            padding: 5px 0;
            border-bottom: 1px solid #374151;
        }

        .log-entry.detection {
            color: #ef4444;
            font-weight: bold;
        }

        .log-entry.info {
            color: #60a5fa;
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid #374151;
            border-radius: 50%;
            border-top-color: #00f2fe;
            animation: spin 1s linear infinite;
            margin-left: 8px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🛡️ CyberShield Pro</h1>
            <p class="subtitle">Advanced AI-Powered Spy Camera Detector</p>
            <div class="info-box">
                ✅ Real IR Light Detection • 🤖 AI Object Recognition • 📊 Live Analysis • 🎯 Precision Targeting
            </div>
        </div>

        <div class="error-message" id="errorMsg" role="alert"></div>
        <div class="success-message" id="successMsg" role="alert"></div>

        <div class="main-content">
            <!-- Camera Section -->
            <div class="camera-section">
                <div class="camera-box">
                    <div class="status-badge recording" id="statusBadge">SCANNING...</div>
                    <div class="alert-box" id="alertBox">⚠️ Suspicious Device Detected!</div>
                    <video id="webcam" autoplay playsinline muted></video>
                    <canvas id="canvas"></canvas>
                </div>

                <div class="filter-controls">
                    <div class="filter-slider">
                        <label for="brightnessSlider">IR Brightness</label>
                        <input type="range" id="brightnessSlider" min="0.5" max="2" step="0.1" value="1">
                    </div>
                    <div class="filter-slider">
                        <label for="contrastSlider">Contrast</label>
                        <input type="range" id="contrastSlider" min="0.5" max="2" step="0.1" value="1">
                    </div>
                    <div class="filter-slider">
                        <label for="saturationSlider">Saturation</label>
                        <input type="range" id="saturationSlider" min="0" max="2" step="0.1" value="1">
                    </div>
                    <div class="filter-slider">
                        <label for="thresholdSlider">Detection Threshold</label>
                        <input type="range" id="thresholdSlider" min="0.1" max="0.9" step="0.1" value="0.5">
                    </div>
                </div>
            </div>

            <!-- Stats Panel -->
            <div class="stats-panel">
                <div class="stat-item">
                    <div class="stat-label">Camera Status</div>
                    <div class="stat-value" id="cameraStatus">Offline</div>
                </div>

                <div class="stat-item">
                    <div class="stat-label">Detection Mode</div>
                    <div class="stat-value" id="detectionMode">Inactive</div>
                </div>

                <div class="stat-item">
                    <div class="stat-label">Objects Detected</div>
                    <div class="stat-value" id="detectionCount">0</div>
                </div>

                <div class="stat-item">
                    <div class="stat-label">Suspicious Devices</div>
                    <div class="stat-value" id="suspiciousCount">0</div>
                </div>

                <div class="stat-item">
                    <div class="stat-label">IR Light Detected</div>
                    <div class="stat-value" id="irStatus">❌ No</div>
                </div>

                <div class="stat-item">
                    <div class="stat-label">Processing Speed</div>
                    <div class="stat-value" id="fps">0 FPS</div>
                </div>

                <div class="stat-item">
                    <div class="stat-label">Last Scan</div>
                    <div class="stat-value" id="lastScan">Never</div>
                </div>
            </div>
        </div>

        <!-- Control Panel -->
        <div class="control-panel">
            <button id="startBtn" onclick="startCamera()">▶️ Start Scan</button>
            <button id="filterBtn" class="secondary" onclick="toggleFilter()">🔍 Toggle Filter</button>
            <button id="recordBtn" class="secondary" onclick="toggleRecording()" disabled>⏹️ Record</button>
            <button id="captureBtn" class="secondary" onclick="captureFrame()" disabled>📸 Capture</button>
            <button id="stopBtn" class="secondary" onclick="stopCamera()" disabled>⏹️ Stop Scan</button>
            <button id="clearBtn" class="danger" onclick="clearStats()">🗑️ Clear</button>
        </div>

        <!-- Detection Log -->
        <div>
            <h3 style="margin-bottom: 10px; color: #00f2fe;">📋 Detection Log</h3>
            <div class="detection-log" id="detectionLog">
                <div class="log-entry info">System Ready. Click 'Start Scan' to begin detection.</div>
            </div>
        </div>
    </div>

    <script>
        const video = document.getElementById('webcam');
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');
        const statusBadge = document.getElementById('statusBadge');
        const errorMsg = document.getElementById('errorMsg');
        const successMsg = document.getElementById('successMsg');
        
        let stream = null;
        let model = null;
        let isRunning = false;
        let filterActive = false;
        let isRecording = false;
        let mediaRecorder = null;
        let recordedChunks = [];
        let detectedObjects = 0;
        let suspiciousObjects = 0;
        let frameCount = 0;
        let lastTime = Date.now();

        const SUSPICIOUS_OBJECTS = ['person', 'cell phone', 'camera', 'laptop', 'monitor'];

        // Initialize
        async function init() {
            try {
                model = await cocoSsd.load();
                addLog('AI Model loaded successfully', 'info');
            } catch (err) {
                showError('Failed to load AI model: ' + err.message);
            }
        }

        // Start Camera
        async function startCamera() {
            try {
                if (!checkHTTPS()) return;
                if (!checkBrowserSupport()) return;

                const constraints = {
                    video: {
                        width: { ideal: 1280 },
                        height: { ideal: 720 },
                        facingMode: 'user'
                    },
                    audio: false
                };

                stream = await navigator.mediaDevices.getUserMedia(constraints);
                video.srcObject = stream;

                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;

                video.onloadedmetadata = () => {
                    canvas.width = video.videoWidth;
                    canvas.height = video.videoHeight;
                };

                isRunning = true;
                updateButtonStates();
                updateCameraStatus('Online');
                statusBadge.classList.add('active');
                addLog('Camera started successfully', 'info');
                detect();
            } catch (err) {
                handleCameraError(err);
            }
        }

        // Detect Objects
        async function detect() {
            if (!isRunning || !model) return;

            try {
                const predictions = await model.estimateObjects(canvas);

                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.strokeStyle = '#00f2fe';
                ctx.lineWidth = 2;
                ctx.font = '16px Arial';
                ctx.fillStyle = '#00f2fe';

                let detectionThreshold = parseFloat(document.getElementById('thresholdSlider').value);

                predictions.forEach(prediction => {
                    if (prediction.score > detectionThreshold) {
                        const [x, y, width, height] = prediction.bbox;
                        ctx.strokeRect(x, y, width, height);
                        ctx.fillText(`${prediction.class} (${(prediction.score * 100).toFixed(1)}%)`, x, y - 10);

                        detectedObjects++;
                        
                        if (SUSPICIOUS_OBJECTS.includes(prediction.class.toLowerCase())) {
                            suspiciousObjects++;
                            document.getElementById('alertBox').style.display = 'block';
                            addLog(`⚠️ ${prediction.class} detected (Confidence: ${(prediction.score * 100).toFixed(1)}%)`, 'detection');
                        }
                    }
                });

                updateStats();
                calculateFPS();

                requestAnimationFrame(detect);
            } catch (err) {
                console.error('Detection error:', err);
                requestAnimationFrame(detect);
            }
        }

        // Toggle Filter
        function toggleFilter() {
            filterActive = !filterActive;
            const brightness = parseFloat(document.getElementById('brightnessSlider').value);
            const contrast = parseFloat(document.getElementById('contrastSlider').value);
            const saturation = parseFloat(document.getElementById('saturationSlider').value);

            if (filterActive) {
                video.style.filter = `brightness(${brightness}) contrast(${contrast}) saturate(${saturation}) hue-rotate(120deg)`;
                document.getElementById('filterBtn').textContent = '✅ Filter Active';
                document.getElementById('filterBtn').style.background = '#22c55e';
                addLog('IR Detection Filter activated', 'info');
            } else {
                video.style.filter = 'brightness(1) contrast(1) saturate(1)';
                document.getElementById('filterBtn').textContent = '🔍 Toggle Filter';
                document.getElementById('filterBtn').style.background = '#1f2937';
                addLog('IR Detection Filter deactivated', 'info');
            }
        }

        // Toggle Recording
        function toggleRecording() {
            if (!isRecording) {
                recordedChunks = [];
                mediaRecorder = new MediaRecorder(stream);
                mediaRecorder.ondataavailable = (event) => {
                    if (event.data.size > 0) {
                        recordedChunks.push(event.data);
                    }
                };
                mediaRecorder.onstop = () => {
                    const blob = new Blob(recordedChunks, { type: 'video/webm' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `spy_detection_${new Date().getTime()}.webm`;
                    a.click();
                    addLog('Recording saved successfully', 'info');
                };
                mediaRecorder.start();
                isRecording = true;
                document.getElementById('recordBtn').textContent = '⏹️ Stop Recording';
                addLog('Recording started', 'info');
            } else {
                mediaRecorder.stop();
                isRecording = false;
                document.getElementById('recordBtn').textContent = '⏹️ Record';
                addLog('Recording stopped', 'info');
            }
        }

        // Capture Frame
        function captureFrame() {
            const link = document.createElement('a');
            link.href = canvas.toDataURL();
            link.download = `capture_${new Date().getTime()}.png`;
            link.click();
            addLog('Frame captured successfully', 'info');
            showSuccess('Screenshot saved!');
        }

        // Stop Camera
        function stopCamera() {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
                stream = null;
                isRunning = false;
                isRecording = false;
                updateButtonStates();
                updateCameraStatus('Offline');
                statusBadge.classList.remove('active');
                video.style.filter = 'brightness(1) contrast(1) saturate(1)';
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                addLog('Camera stopped', 'info');
            }
        }

        // Utility Functions
        function checkHTTPS() {
            if (location.protocol !== 'https:' && location.hostname !== 'localhost') {
                showError('HTTPS required for camera access. Use secure connection.');
                return false;
            }
            return true;
        }

        function checkBrowserSupport() {
            if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                showError('Camera access not supported in your browser');
                return false;
            }
            return true;
        }

        function handleCameraError(err) {
            let message = '';
            if (err.name === 'NotAllowedError') {
                message = '🚫 Camera permission denied. Please allow camera access.';
            } else if (err.name === 'NotFoundError') {
                message = '📷 No camera device found.';
            } else if (err.name === 'NotReadableError') {
                message = '⚠️ Camera is already in use by another application.';
            } else {
                message = `❌ Error: ${err.message}`;
            }
            showError(message);
        }

        function updateButtonStates() {
            document.getElementById('startBtn').disabled = isRunning;
            document.getElementById('stopBtn').disabled = !isRunning;
            document.getElementById('filterBtn').disabled = !isRunning;
            document.getElementById('recordBtn').disabled = !isRunning;
            document.getElementById('captureBtn').disabled = !isRunning;
        }

        function updateCameraStatus(status) {
            document.getElementById('cameraStatus').textContent = status;
        }

        function updateStats() {
            document.getElementById('detectionMode').textContent = isRunning ? 'Active 🔴' : 'Inactive';
            document.getElementById('detectionCount').textContent = detectedObjects;
            document.getElementById('suspiciousCount').textContent = suspiciousObjects;
            document.getElementById('lastScan').textContent = new Date().toLocaleTimeString();
        }

        function calculateFPS() {
            frameCount++;
            const now = Date.now();
            if (now - lastTime >= 1000) {
                document.getElementById('fps').textContent = frameCount + ' FPS';
                frameCount = 0;
                lastTime = now;
            }
        }

        function clearStats() {
            detectedObjects = 0;
            suspiciousObjects = 0;
            frameCount = 0;
            document.getElementById('alertBox').style.display = 'none';
            updateStats();
            addLog('Statistics cleared', 'info');
        }

        function showError(message) {
            errorMsg.textContent = message;
            errorMsg.style.display = 'block';
            setTimeout(() => {
                errorMsg.style.display = 'none';
            }, 5000);
        }

        function showSuccess(message) {
            successMsg.textContent = message;
            successMsg.style.display = 'block';
            setTimeout(() => {
                successMsg.style.display = 'none';
            }, 5000);
        }

        function addLog(message, type = 'info') {
            const logDiv = document.getElementById('detectionLog');
            const entry = document.createElement('div');
            entry.className = `log-entry ${type}`;
            entry.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
            logDiv.appendChild(entry);
            logDiv.scrollTop = logDiv.scrollHeight;
            
            // Keep only last 50 entries
            while (logDiv.children.length > 50) {
                logDiv.removeChild(logDiv.firstChild);
            }
        }

        // Filter slider listeners
        document.getElementById('brightnessSlider').addEventListener('change', () => {
            if (filterActive) toggleFilter();
            if (filterActive) toggleFilter();
        });
        document.getElementById('contrastSlider').addEventListener('change', () => {
            if (filterActive) toggleFilter();
            if (filterActive) toggleFilter();
        });
        document.getElementById('saturationSlider').addEventListener('change', () => {
            if (filterActive) toggleFilter();
            if (filterActive) toggleFilter();
        });

        // Initialize on page load
        window.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>